#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CERTS_DIR="${SCRIPT_DIR}/nginx/certs"
PROJECTS_DIR="${SCRIPT_DIR}/projects"

# Helper: Detect current project if inside projects/ subdirectory
detect_current_project() {
    local cwd="$(pwd)"
    if [[ "$cwd" == "$PROJECTS_DIR"* ]] && [[ "$cwd" != "$PROJECTS_DIR" ]]; then
        local rel_path="${cwd#$PROJECTS_DIR/}"
        echo "${rel_path%%/*}"
    else
        echo ""
    fi
}

# Helper: Ensure SSL certs exist (creates self-signed fallback if missing)
ensure_ssl() {
    mkdir -p "$CERTS_DIR"
    if [[ ! -f "$CERTS_DIR/local-dev.crt" ]] || [[ ! -f "$CERTS_DIR/local-dev.key" ]]; then
        generate_ssl
    fi
}

# Generate SSL certificates (hybrid mkcert / openssl fallback)
generate_ssl() {
    mkdir -p "$CERTS_DIR"
    if command -v mkcert &> /dev/null; then
        echo "🔒 Using mkcert to generate trusted local SSL certificates..."
        mkcert -cert-file "$CERTS_DIR/local-dev.crt" -key-file "$CERTS_DIR/local-dev.key" \
            "*.php82.test" "*.php83.test" "*.php84.test" "*.php85.test" "*.test" localhost 127.0.0.1 ::1
        echo "✅ Trusted SSL certificates generated at nginx/certs/"
    else
        echo "⚠️ mkcert not found on host system. Falling back to OpenSSL self-signed certificate..."
        openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
            -keyout "$CERTS_DIR/local-dev.key" \
            -out "$CERTS_DIR/local-dev.crt" \
            -subj "/C=US/ST=Local/L=Local/O=LocalDev/OU=Dev/CN=*.test" \
            &> /dev/null
        echo "✅ Self-signed SSL certificate generated at nginx/certs/"
        echo "💡 Note: Install 'mkcert' on your host system for browser-trusted local HTTPS!"
    fi
}

# Auto-create database if not exists
create_db_if_not_exists() {
    local db_type="$1"
    local db_name="$2"
    db_name="${db_name//-/_}" # sanitize hyphens to underscores for DB names

    if [[ "$db_type" == "mariadb" || "$db_type" == "mysql" ]]; then
        echo "🗄️  Checking/Creating MariaDB database: ${db_name}..."
        docker exec -i local-mariadb mariadb -u db_user -pdb_password -e "CREATE DATABASE IF NOT EXISTS \`${db_name}\`;" 2>/dev/null || {
            echo "⚠️ Could not auto-create MariaDB database (make sure containers are running with './dev up')."
        }
    elif [[ "$db_type" == "postgres" || "$db_type" == "pgsql" ]]; then
        echo "🗄️  Checking/Creating PostgreSQL database: ${db_name}..."
        docker exec -i local-postgres psql -U db_user -d local_db -c "CREATE DATABASE ${db_name};" 2>/dev/null || true
    fi
}

# Setup local DNS resolution (*.test)
setup_dns() {
    echo "🌐 Setting up local DNS resolution for *.test domains..."
    
    local os="$(uname -s)"
    
    if [[ "$os" == "Linux" ]]; then
        if systemctl is-active --quiet systemd-resolved 2>/dev/null || systemctl is-enabled --quiet systemd-resolved 2>/dev/null; then
            echo "🔧 Configuring systemd-resolved for *.test domains..."
            sudo mkdir -p /etc/systemd/resolved.conf.d
            cat <<EOF | sudo tee /etc/systemd/resolved.conf.d/localdev.conf > /dev/null
[Resolve]
DNS=127.0.0.1:5353
Domains=~test
EOF
            echo "🔄 Restarting systemd-resolved service..."
            sudo systemctl restart systemd-resolved
            echo "✅ systemd-resolved configured successfully for *.test domains!"
        elif [[ -d /etc/NetworkManager/conf.d ]]; then
            echo "🔧 Configuring NetworkManager dnsmasq plugin for *.test domains..."
            echo -e "[main]\ndns=dnsmasq" | sudo tee /etc/NetworkManager/conf.d/00-use-dnsmasq.conf > /dev/null
            sudo mkdir -p /etc/NetworkManager/dnsmasq.d
            echo "server=/test/127.0.0.1#5353" | sudo tee /etc/NetworkManager/dnsmasq.d/localdev.conf > /dev/null
            sudo systemctl restart NetworkManager
            echo "✅ NetworkManager configured successfully!"
        else
            echo "⚠️ Could not auto-detect systemd-resolved or NetworkManager."
            echo "💡 Please add 'nameserver 127.0.0.1' or point port 5353 in your resolver configuration."
        fi
    elif [[ "$os" == "Darwin" ]]; then
        echo "🔧 Configuring macOS resolver for *.test domains..."
        sudo mkdir -p /etc/resolver
        cat <<EOF | sudo tee /etc/resolver/test > /dev/null
nameserver 127.0.0.1
port 5353
EOF
        echo "✅ macOS resolver created at /etc/resolver/test!"
    else
        echo "ℹ️ On Windows/WSL2, ensure local-dnsmasq container is running and route *.test requests to 127.0.0.1."
    fi

    echo ""
    check_dns_status
}

# Test local DNS resolution status
check_dns_status() {
    echo "🔍 Checking *.test DNS resolution status..."
    local test_domain="localdev-test.test"
    local resolved_ip=""

    if command -v dig &>/dev/null; then
        resolved_ip="$(dig +short @127.0.0.1 -p 5353 "$test_domain" 2>/dev/null | tail -n1)"
    elif command -v nslookup &>/dev/null; then
        resolved_ip="$(nslookup -port=5353 "$test_domain" 127.0.0.1 2>/dev/null | grep -A1 "Name:" | grep "Address:" | awk '{print $2}')"
    fi

    if [[ "$resolved_ip" == "127.0.0.1" ]]; then
        echo "✅ Dnsmasq container (127.0.0.1:5353) is resolving *.test domains correctly to 127.0.0.1"
    else
        echo "⚠️ Direct query to Dnsmasq container (127.0.0.1:5353) returned: '${resolved_ip:-no response}'"
        echo "💡 Make sure containers are started with './dev up'."
    fi

    if command -v ping &>/dev/null; then
        if ping -c 1 -W 1 "$test_domain" &>/dev/null; then
            echo "✅ Host OS resolver successfully resolves *.test domains!"
        else
            echo "ℹ️ Host OS ping test to $test_domain did not resolve. Run './dev dns setup' to configure host DNS."
        fi
    fi
}

# Remove local DNS setup
teardown_dns() {
    echo "🧹 Cleaning up local DNS configurations..."
    local os="$(uname -s)"

    if [[ "$os" == "Linux" ]]; then
        if [[ -f /etc/systemd/resolved.conf.d/localdev.conf ]]; then
            sudo rm -f /etc/systemd/resolved.conf.d/localdev.conf
            sudo systemctl restart systemd-resolved 2>/dev/null || true
            echo "✅ Removed /etc/systemd/resolved.conf.d/localdev.conf"
        fi
        if [[ -f /etc/NetworkManager/dnsmasq.d/localdev.conf ]]; then
            sudo rm -f /etc/NetworkManager/dnsmasq.d/localdev.conf
            sudo systemctl restart NetworkManager 2>/dev/null || true
            echo "✅ Removed /etc/NetworkManager/dnsmasq.d/localdev.conf"
        fi
    elif [[ "$os" == "Darwin" ]]; then
        if [[ -f /etc/resolver/test ]]; then
            sudo rm -f /etc/resolver/test
            echo "✅ Removed /etc/resolver/test"
        fi
    fi
    echo "✨ Teardown complete."
}

# Install shell completions into user's profile
install_completion() {
    local shell_name="${SHELL##*/}"
    echo "🔧 Installing './dev' shell completions for ${shell_name}..."

    if [[ "$shell_name" == "zsh" ]]; then
        local zshrc="$HOME/.zshrc"
        if ! grep -q "compdef _dev dev" "$zshrc" 2>/dev/null; then
            echo "" >> "$zshrc"
            echo "# localDev CLI completions" >> "$zshrc"
            echo "source <($SCRIPT_DIR/dev completion zsh)" >> "$zshrc"
            echo "✅ Added completion loader to $zshrc"
            echo "💡 Run 'source ~/.zshrc' to enable completion in current terminal session."
        else
            echo "ℹ️ Completions already configured in $zshrc"
        fi
    elif [[ "$shell_name" == "bash" ]]; then
        local bashrc="$HOME/.bashrc"
        if ! grep -q "_dev_completion" "$bashrc" 2>/dev/null; then
            echo "" >> "$bashrc"
            echo "# localDev CLI completions" >> "$bashrc"
            echo "source <($SCRIPT_DIR/dev completion bash)" >> "$bashrc"
            echo "✅ Added completion loader to $bashrc"
            echo "💡 Run 'source ~/.bashrc' to enable completion in current terminal session."
        else
            echo "ℹ️ Completions already configured in $bashrc"
        fi
    elif [[ "$shell_name" == "fish" ]]; then
        local fish_dir="$HOME/.config/fish/completions"
        mkdir -p "$fish_dir"
        "$SCRIPT_DIR/dev" completion fish > "$fish_dir/dev.fish"
        echo "✅ Installed fish completions to $fish_dir/dev.fish"
    else
        echo "⚠️ Unsupported shell '$shell_name'. Supported shells: zsh, bash, fish."
    fi
}

# Helper to determine target PHP container name from flag or default (php84)
get_php_container() {
    local raw_ver="$1"
    case "$raw_ver" in
        8.2|82) echo "local-php82" ;;
        8.3|83) echo "local-php83" ;;
        8.4|84) echo "local-php84" ;;
        8.5|85) echo "local-php85" ;;
        *)      echo "local-php84" ;;
    esac
}


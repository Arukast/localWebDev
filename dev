# Main routing logic
case "$1" in
    up)
        ensure_ssl
        shift
        use_tools=false
        args=()
        for arg in "$@"; do
            if [[ "$arg" == "--tools" || "$arg" == "--all" ]]; then
                use_tools=true
            else
                args+=("$arg")
            fi
        done

        if [ "$use_tools" = true ]; then
            docker compose -f "$SCRIPT_DIR/docker-compose.yml" --profile tools up -d "${args[@]}"
        else
            docker compose -f "$SCRIPT_DIR/docker-compose.yml" up -d "${args[@]}"
        fi
        ;;

    down)
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" --profile tools down "$@"
        ;;

    restart)
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" restart "$@"
        ;;

    logs)
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" logs "$@"
        ;;

    status|ps)
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" ps "$@"
        ;;

    ssl)
        generate_ssl
        ;;

    dns)
        shift
        case "$1" in
            setup)
                setup_dns
                ;;
            status)
                check_dns_status
                ;;
            teardown|uninstall|remove)
                teardown_dns
                ;;
            *)
                echo "Usage: ./dev dns [setup|status|teardown]"
                ;;
        esac
        ;;

    new)
        shift
        if [[ -z "$1" ]]; then
            echo "❌ Error: Project name required."
            echo "Usage: ./dev new <project_name> [--type=laravel|wordpress|symfony|vite|blank] [--php=8.4|8.3|8.2|8.5] [--db=mariadb|postgres]"
            exit 1
        fi

        proj_name="$1"
        shift
        type="laravel"
        php_ver="8.4"
        db_type="mariadb"

        for arg in "$@"; do
            case $arg in
                --type=*) type="${arg#*=}" ;;
                --php=*) php_ver="${arg#*=}" ;;
                --db=*) db_type="${arg#*=}" ;;
            esac
        done

        php_container=$(get_php_container "$php_ver")
        target_dir="$PROJECTS_DIR/$proj_name"

        if [[ -d "$target_dir" ]]; then
            echo "❌ Error: Directory projects/$proj_name already exists!"
            exit 1
        fi

        echo "🚀 Scaffolding new '$type' project '$proj_name' (PHP $php_ver, DB: $db_type)..."

        db_name="${proj_name//-/_}"
        create_db_if_not_exists "$db_type" "$db_name"

        mkdir -p "$target_dir"

        if [[ "$type" == "laravel" ]]; then
            echo "📦 Running 'composer create-project laravel/laravel'..."
            docker exec -it -w "/var/www/html" "$php_container" composer create-project laravel/laravel "$proj_name"

            if [[ -f "$target_dir/.env" ]]; then
                sed -i "s/DB_HOST=.*/DB_HOST=$db_type/" "$target_dir/.env"
                sed -i "s/DB_DATABASE=.*/DB_DATABASE=$db_name/" "$target_dir/.env"
                sed -i "s/DB_USERNAME=.*/DB_USERNAME=db_user/" "$target_dir/.env"
                sed -i "s/DB_PASSWORD=.*/DB_PASSWORD=db_password/" "$target_dir/.env"
                sed -i "s/REDIS_HOST=.*/REDIS_HOST=redis/" "$target_dir/.env"
                sed -i "s/MAIL_HOST=.*/MAIL_HOST=mailpit/" "$target_dir/.env"
                sed -i "s/MAIL_PORT=.*/MAIL_PORT=1025/" "$target_dir/.env"
            fi
            echo "✅ Laravel project '$proj_name' created successfully!"

        elif [[ "$type" == "symfony" ]]; then
            echo "📦 Running 'composer create-project symfony/skeleton'..."
            docker exec -it -w "/var/www/html" "$php_container" composer create-project symfony/skeleton "$proj_name"
            echo "✅ Symfony project '$proj_name' created successfully!"

        elif [[ "$type" == "vite" ]]; then
            echo "📦 Setting up Vite frontend app..."
            docker exec -it -w "/var/www/html" "$php_container" npm create vite@latest "$proj_name" -- --template vanilla
            echo "✅ Vite project '$proj_name' created successfully!"

        elif [[ "$type" == "wordpress" ]]; then
            echo "📦 Setting up WordPress..."
            curl -sSL https://wordpress.org/latest.tar.gz | tar -xz -C "$PROJECTS_DIR"
            mv "$PROJECTS_DIR/wordpress" "$target_dir"

            cat <<EOF > "$target_dir/wp-config.php"
<?php
define( 'DB_NAME', '${db_name}' );
define( 'DB_USER', 'db_user' );
define( 'DB_PASSWORD', 'db_password' );
define( 'DB_HOST', '${db_type}' );
define( 'DB_CHARSET', 'utf8mb4' );
define( 'DB_COLLATE', '' );

\$table_prefix = 'wp_';
define( 'WP_DEBUG', true );

if ( ! defined( 'ABSPATH' ) ) {
    define( 'ABSPATH', __DIR__ . '/' );
}
require_once ABSPATH . 'wp-settings.php';
EOF
            echo "✅ WordPress project '$proj_name' created successfully!"

        else
            echo "📦 Setting up Blank/Vanilla PHP project..."
            cat <<EOF > "$target_dir/index.php"
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${proj_name} - localDev</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #0f172a; color: #f8fafc; display: grid; place-content: center; min-height: 100vh; margin: 0; }
        .card { background: #1e293b; padding: 2rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.5); text-align: center; max-width: 500px; }
        h1 { color: #38bdf8; margin-bottom: 0.5rem; }
        p { color: #94a3b8; }
        .badge { background: #0284c7; padding: 4px 10px; border-radius: 9999px; font-size: 0.875rem; font-weight: bold; }
    </style>
</head>
<body>
    <div class="card">
        <h1>🚀 ${proj_name}</h1>
        <p>Your localDev environment is ready!</p>
        <p><span class="badge">PHP <?php echo phpversion(); ?></span></p>
    </div>
</body>
</html>
EOF
            echo "✅ Blank project '$proj_name' created successfully!"
        fi

        echo ""
        echo "🌐 Available Test URLs:"
        echo "  - HTTPS (Default 8.4): https://${proj_name}.test"
        echo "  - HTTPS (PHP 8.4):     https://${proj_name}.php84.test"
        echo "  - HTTPS (PHP 8.3):     https://${proj_name}.php83.test"
        echo "  - HTTPS (PHP 8.2):     https://${proj_name}.php82.test"
        echo "  - HTTP (Fallback):     http://localhost:8084/${proj_name}"
        ;;

    list)
        echo "========================================================================================="
        echo " 📁 localDev Projects Overview"
        echo "========================================================================================="
        printf "%-18s %-12s %-32s %-25s\n" "PROJECT" "TYPE" "HTTPS DOMAIN (*.test)" "PORT FALLBACK"
        echo "----------------------------------------------------------------------------------------- shadow"

        for pdir in "$PROJECTS_DIR"/*; do
            if [[ -d "$pdir" ]]; then
                pname="$(basename "$pdir")"
                ptype="Vanilla/PHP"
                if [[ -f "$pdir/artisan" ]]; then
                    ptype="Laravel"
                elif [[ -f "$pdir/wp-config.php" ]]; then
                    ptype="WordPress"
                elif [[ -f "$pdir/symfony.lock" ]]; then
                    ptype="Symfony"
                elif [[ -f "$pdir/vite.config.js" || -f "$pdir/vite.config.ts" ]]; then
                    ptype="Vite/Node"
                fi

                domain="https://${pname}.test"
                fallback="http://localhost:8084/${pname}"

                printf "%-18s %-12s %-32s %-25s\n" "$pname" "$ptype" "$domain" "$fallback"
            fi
        done
        echo "========================================================================================="
        ;;

    share)
        shift
        proj="$1"
        if [[ -z "$proj" ]]; then
            proj=$(detect_current_project)
        fi

        if [[ -z "$proj" ]]; then
            echo "❌ Error: Project name required."
            echo "Usage: ./dev share <project-name> (or run from inside projects/<project-name>)"
            exit 1
        fi

        echo "🌐 Exposing project '$proj' publicly via Cloudflare Tunnel..."
        echo "💡 Press Ctrl+C to terminate the tunnel."
        echo ""
        docker run --rm -it --net=host cloudflare/cloudflared:latest tunnel --url "http://127.0.0.1:8084/$proj"
        ;;

    composer)
        shift
        raw_ver="8.4"
        case "$1" in
            8.2|82|8.3|83|8.4|84|8.5|85)
                raw_ver="$1"
                shift
                ;;
        esac
        container=$(get_php_container "$raw_ver")

        proj=$(detect_current_project)
        workdir="/var/www/html"
        if [[ -n "$proj" ]]; then
            workdir="/var/www/html/$proj"
        fi

        docker exec -it -w "$workdir" "$container" composer "$@"
        ;;

    artisan)
        shift
        raw_ver="8.4"
        proj=$(detect_current_project)

        if [[ -d "$PROJECTS_DIR/$1" ]]; then
            proj="$1"
            shift
        fi

        if [[ -z "$proj" ]]; then
            echo "❌ Error: Could not determine target project name."
            echo "Usage: ./dev artisan <project-name> <command>  (or run from inside projects/<project-name>)"
            exit 1
        fi

        container=$(get_php_container "$raw_ver")
        docker exec -it -w "/var/www/html/$proj" "$container" php artisan "$@"
        ;;

    php)
        shift
        raw_ver="8.4"
        case "$1" in
            8.2|82|8.3|83|8.4|84|8.5|85)
                raw_ver="$1"
                shift
                ;;
        esac
        container=$(get_php_container "$raw_ver")

        proj=$(detect_current_project)
        workdir="/var/www/html"
        if [[ -n "$proj" ]]; then
            workdir="/var/www/html/$proj"
        fi

        docker exec -it -w "$workdir" "$container" php "$@"
        ;;

    npm)
        shift
        raw_ver="8.4"
        case "$1" in
            8.2|82|8.3|83|8.4|84|8.5|85)
                raw_ver="$1"
                shift
                ;;
        esac
        container=$(get_php_container "$raw_ver")

        proj=$(detect_current_project)
        workdir="/var/www/html"
        if [[ -n "$proj" ]]; then
            workdir="/var/www/html/$proj"
        fi

        docker exec -it -w "$workdir" "$container" npm "$@"
        ;;

    npx)
        shift
        raw_ver="8.4"
        case "$1" in
            8.2|82|8.3|83|8.4|84|8.5|85)
                raw_ver="$1"
                shift
                ;;
        esac
        container=$(get_php_container "$raw_ver")

        proj=$(detect_current_project)
        workdir="/var/www/html"
        if [[ -n "$proj" ]]; then
            workdir="/var/www/html/$proj"
        fi

        docker exec -it -w "$workdir" "$container" npx "$@"
        ;;

    node)
        shift
        raw_ver="8.4"
        case "$1" in
            8.2|82|8.3|83|8.4|84|8.5|85)
                raw_ver="$1"
                shift
                ;;
        esac
        container=$(get_php_container "$raw_ver")

        proj=$(detect_current_project)
        workdir="/var/www/html"
        if [[ -n "$proj" ]]; then
            workdir="/var/www/html/$proj"
        fi

        docker exec -it -w "$workdir" "$container" node "$@"
        ;;

    db)
        shift
        action="$1"
        shift || true
        db_type="$1"
        shift || true

        if [[ "$action" == "shell" ]]; then
            if [[ "$db_type" == "mariadb" || "$db_type" == "mysql" ]]; then
                echo "💻 Connecting to MariaDB interactive shell..."
                docker exec -it local-mariadb mariadb -u db_user -pdb_password local_db
            elif [[ "$db_type" == "postgres" || "$db_type" == "pgsql" ]]; then
                echo "💻 Connecting to PostgreSQL interactive shell..."
                docker exec -it local-postgres psql -U db_user -d local_db
            else
                echo "Usage: ./dev db shell <mariadb|postgres>"
            fi

        elif [[ "$action" == "backup" ]]; then
            outfile="${1:-${db_type}_backup_$(date +%Y%m%d_%H%M%S).sql}"
            if [[ "$db_type" == "mariadb" || "$db_type" == "mysql" ]]; then
                echo "📦 Exporting MariaDB to $outfile..."
                docker exec -i local-mariadb mariadb-dump -u db_user -pdb_password local_db > "$outfile"
                echo "✅ Mariadb dump completed: $outfile"
            elif [[ "$db_type" == "postgres" || "$db_type" == "pgsql" ]]; then
                echo "📦 Exporting PostgreSQL to $outfile..."
                docker exec -t local-postgres pg_dump -U db_user local_db > "$outfile"
                echo "✅ PostgreSQL dump completed: $outfile"
            else
                echo "❌ Unknown db_type: $db_type (Use 'mariadb' or 'postgres')"
                exit 1
            fi
        elif [[ "$action" == "restore" ]]; then
            infile="$1"
            if [[ ! -f "$infile" ]]; then
                echo "❌ Restore file not found: $infile"
                exit 1
            fi
            if [[ "$db_type" == "mariadb" || "$db_type" == "mysql" ]]; then
                echo "📥 Importing $infile into MariaDB..."
                docker exec -i local-mariadb mariadb -u db_user -pdb_password local_db < "$infile"
                echo "✅ Mariadb restore completed!"
            elif [[ "$db_type" == "postgres" || "$db_type" == "pgsql" ]]; then
                echo "📥 Importing $infile into PostgreSQL..."
                docker exec -i local-postgres psql -U db_user -d local_db < "$infile"
                echo "✅ PostgreSQL restore completed!"
            else
                echo "❌ Unknown db_type: $db_type (Use 'mariadb' or 'postgres')"
                exit 1
            fi
        else
            echo "Usage: ./dev db shell <mariadb|postgres>"
            echo "       ./dev db backup <mariadb|postgres> [file.sql]"
            echo "       ./dev db restore <mariadb|postgres> <file.sql>"
        fi
        ;;

    completion)
        shell="${2:-bash}"
        if [[ "$shell" == "install" ]]; then
            install_completion
        elif [[ "$shell" == "zsh" ]]; then

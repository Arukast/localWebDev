#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CERTS_DIR="${SCRIPT_DIR}/nginx/certs"
PROJECTS_DIR="${SCRIPT_DIR}/projects"

# Helper: Detect current project if inside projects/ subdirectory
detect_current_project() {
    local cwd="$(pwd)"
    if [[ "$cwd" == "$PROJECTS_DIR"* ]] && [[ "$cwd" != "$PROJECTS_DIR" ]]; then
        local rel_path="${cwd#$PROJECTS_DIR/}"
        echo "${rel_path%%/*}"
    else
        echo ""
    fi
}

# Helper: Ensure SSL certs exist (creates self-signed fallback if missing)
ensure_ssl() {
    mkdir -p "$CERTS_DIR"
    if [[ ! -f "$CERTS_DIR/local-dev.crt" ]] || [[ ! -f "$CERTS_DIR/local-dev.key" ]]; then
        generate_ssl
    fi
}

# Generate SSL certificates (hybrid mkcert / openssl fallback)
generate_ssl() {
    mkdir -p "$CERTS_DIR"
    if command -v mkcert &> /dev/null; then
        echo "🔒 Using mkcert to generate trusted local SSL certificates..."
        mkcert -cert-file "$CERTS_DIR/local-dev.crt" -key-file "$CERTS_DIR/local-dev.key" "*.php82.test" "*.php83.test" "*.test" localhost 127.0.0.1 ::1
        echo "✅ Trusted SSL certificates generated at nginx/certs/"
    else
        echo "⚠️ mkcert not found on host system. Falling back to OpenSSL self-signed certificate..."
        openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
            -keyout "$CERTS_DIR/local-dev.key" \
            -out "$CERTS_DIR/local-dev.crt" \
            -subj "/C=US/ST=Local/L=Local/O=LocalDev/OU=Dev/CN=*.test" \
            &> /dev/null
        echo "✅ Self-signed SSL certificate generated at nginx/certs/"
        echo "💡 Note: Install 'mkcert' on your host system for browser-trusted local HTTPS!"
    fi
}

show_help() {
    echo "=========================================="
    echo " 🚀 localDev CLI Helper"
    echo "=========================================="
    echo "Usage: ./dev <command> [options]"
    echo ""
    echo "Commands:"
    echo "  up [services...]        Start Docker containers (runs ./dev ssl automatically)"
    echo "  down                    Stop Docker containers"
    echo "  restart [service]       Restart containers"
    echo "  logs [-f] [service]     View container logs"
    echo "  status / ps             View running containers status"
    echo "  ssl                     Generate or renew SSL certs (*.test)"
    echo ""
    echo "Development Helpers:"
    echo "  composer [8.2|8.3] ...  Run Composer inside PHP container (defaults to 8.3)"
    echo "  artisan [app] <cmd>    Run Artisan command for Laravel app"
    echo "  php [8.2|8.3] ...      Run PHP CLI command inside container"
    echo "  db backup <mariadb|postgres> [out.sql]   Export database dump"
    echo "  db restore <mariadb|postgres> <in.sql]   Import database dump"
    echo "  help                    Show this help message"
    echo "=========================================="
}

# Main routing logic
case "$1" in
    up)
        ensure_ssl
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" up -d "$@"
        ;;

    down)
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" down "$@"
        ;;

    restart)
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" restart "$@"
        ;;

    logs)
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" logs "$@"
        ;;

    status|ps)
        shift
        docker compose -f "$SCRIPT_DIR/docker-compose.yml" ps "$@"
        ;;

    ssl)
        generate_ssl
        ;;

    composer)
        shift
        php_ver="php83"
        if [[ "$1" == "8.2" ]] || [[ "$1" == "82" ]]; then
            php_ver="php82"
            shift
        elif [[ "$1" == "8.3" ]] || [[ "$1" == "83" ]]; then
            php_ver="php83"
            shift
        fi

        proj=$(detect_current_project)
        workdir="/var/www/html"
        if [[ -n "$proj" ]]; then
            workdir="/var/www/html/$proj"
        fi

        docker exec -it -w "$workdir" "local-$php_ver" composer "$@"
        ;;

    artisan)
        shift
        php_ver="php83"
        proj=$(detect_current_project)

        # Check if first arg is project name
        if [[ -d "$PROJECTS_DIR/$1" ]]; then
            proj="$1"
            shift
        fi

        if [[ -z "$proj" ]]; then
            echo "❌ Error: Could not determine target project name."
            echo "Usage: ./dev artisan <project-name> <command>  (or run from inside projects/<project-name>)"
            exit 1
        fi

        docker exec -it -w "/var/www/html/$proj" "local-$php_ver" php artisan "$@"
        ;;

    php)
        shift
        php_ver="php83"
        if [[ "$1" == "8.2" ]] || [[ "$1" == "82" ]]; then
            php_ver="php82"
            shift
        elif [[ "$1" == "8.3" ]] || [[ "$1" == "83" ]]; then
            php_ver="php83"
            shift
        fi

        proj=$(detect_current_project)
        workdir="/var/www/html"
        if [[ -n "$proj" ]]; then
            workdir="/var/www/html/$proj"
        fi

        docker exec -it -w "$workdir" "local-$php_ver" php "$@"
        ;;

    db)
        shift
        action="$1"
        shift
        db_type="$1"
        shift || true

        if [[ "$action" == "backup" ]]; then
            outfile="${1:-${db_type}_backup_$(date +%Y%m%d_%H%M%S).sql}"
            if [[ "$db_type" == "mariadb" || "$db_type" == "mysql" ]]; then
                echo "📦 Exporting MariaDB to $outfile..."
                docker exec -i local-mariadb mariadb-dump -u db_user -pdb_password local_db > "$outfile"
                echo "✅ Mariadb dump completed: $outfile"
            elif [[ "$db_type" == "postgres" || "$db_type" == "pgsql" ]]; then
                echo "📦 Exporting PostgreSQL to $outfile..."
                docker exec -t local-postgres pg_dump -U db_user local_db > "$outfile"
                echo "✅ PostgreSQL dump completed: $outfile"
            else
                echo "❌ Unknown db_type: $db_type (Use 'mariadb' or 'postgres')"
                exit 1
            fi
        elif [[ "$action" == "restore" ]]; then
            infile="$1"
            if [[ ! -f "$infile" ]]; then
                echo "❌ Restore file not found: $infile"
                exit 1
            fi
            if [[ "$db_type" == "mariadb" || "$db_type" == "mysql" ]]; then
                echo "📥 Importing $infile into MariaDB..."
                docker exec -i local-mariadb mariadb -u db_user -pdb_password local_db < "$infile"
                echo "✅ Mariadb restore completed!"
            elif [[ "$db_type" == "postgres" || "$db_type" == "pgsql" ]]; then
                echo "📥 Importing $infile into PostgreSQL..."
                docker exec -i local-postgres psql -U db_user -d local_db < "$infile"
                echo "✅ PostgreSQL restore completed!"
            else
                echo "❌ Unknown db_type: $db_type (Use 'mariadb' or 'postgres')"
                exit 1
            fi
        else
            echo "Usage: ./dev db backup <mariadb|postgres> [file.sql]"
            echo "       ./dev db restore <mariadb|postgres> <file.sql>"
        fi
        ;;

    help|--help|-h|"")
        show_help
        ;;

    *)
        echo "Unknown command: $1"
        show_help
        exit 1
        ;;
esac

# Ignore local environment variables containing passwords
.env

# Ignore all user projects, but keep our diagnostic landing page
projects/*
!projects/index.php

repomix-output.xml
# Ignore local generated SSL certificates & keys
nginx/certs/

# Ignore environment database & state snapshots
snapshots/

# OS and Editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

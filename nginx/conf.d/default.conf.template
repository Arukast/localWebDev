# =======================================================
# 5. Tailscale Routing for Your Active Project
# =======================================================
server {
    listen 8083;
    server_name ${TAILSCALE_DOMAIN};

    # Auto-detect Laravel public root or user specified path
    set $tailscale_root /var/www/html/${TAILSCALE_PROJECT_PATH};
    if (-d /var/www/html/${TAILSCALE_PROJECT_PATH}/public) {
        set $tailscale_root /var/www/html/${TAILSCALE_PROJECT_PATH}/public;
    }
    if (-f /var/www/html/${TAILSCALE_PROJECT_PATH}/artisan) {
        set $tailscale_root /var/www/html/${TAILSCALE_PROJECT_PATH}/public;
    }
    if (-f /var/www/html/${TAILSCALE_PROJECT_PATH}/index.php) {
        set $tailscale_root /var/www/html/${TAILSCALE_PROJECT_PATH};
    }
    if (-f /var/www/html/${TAILSCALE_PROJECT_PATH}/artisan) {
        set $tailscale_root /var/www/html/${TAILSCALE_PROJECT_PATH}/public;
    }

    root $tailscale_root;
    index index.php index.html;
    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass php83:9000;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }
    location ~ /\.(?!well-known).* { deny all; }
}


# ==========================================
# 1. Dynamic Domain Routing (*.php82.test)
# ==========================================
server {
    listen 80;
    server_name ~^(?<project>.+)\.php82\.test$;

    # Default to public if it exists, fallback to project root
    set $project_root /var/www/html/$project;
    if (-d /var/www/html/$project/public) {
        set $project_root /var/www/html/$project/public;
    }
    if (-f /var/www/html/$project/index.php) {
        set $project_root /var/www/html/$project;
    }
    root $project_root;

    index index.php index.html;
    charset utf-8;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }

    location ~ \.php$ {
        fastcgi_pass php82:9000;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\.(?!well-known).* { deny all; }
}


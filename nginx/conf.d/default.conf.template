# =======================================================
# 3. Port Fallback (PHP 8.2) - Handles Subfolders Cleanly
# =======================================================
server {
    listen 8082;
    server_name localhost;
    root /var/www/html;
    index index.php index.html;
    charset utf-8;

    # Subfolder project routing logic
    location / {
        set $project_name "";
        set $subpath "";

        if ($uri ~ ^/([^/]+)(/.*)?$) {
            set $project_name $1;
            set $subpath $2;
        }

        # 1. Static asset check under public/ (Vite build assets, storage symlinks, CSS/JS/images)
        if (-f /var/www/html/$project_name/public$subpath) {
            rewrite ^/([^/]+)(/.*)?$ /$1/public$2 last;
        }

        # 2. Framework detection (Laravel artisan or public/index.php)
        set $use_public "0";
        if (-d /var/www/html/$project_name/public) {
            set $use_public "1";
        }
        if (-f /var/www/html/$project_name/artisan) {
            set $use_public "1";
        }
        if (-f /var/www/html/$project_name/index.php) {
            set $use_public "0";
        }
        if (-f /var/www/html/$project_name/artisan) {
            set $use_public "1";
        }

        if ($use_public = "1") {
            rewrite ^/([^/]+)(/.*)?$ /$1/public/index.php?$query_string last;
        }

        try_files $uri $uri/ /index.php?$query_string;
    }

    # Global execution block for all PHP processes
    location ~ \.php$ {
        fastcgi_pass php82:9000;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }
    location ~ /\.(?!well-known).* { deny all; }
}


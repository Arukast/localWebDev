# Application Configuration
APP_NAME=my-app
# APP_PATH points to where your PHP project files live (relative to this folder or absolute)
APP_PATH=./app
APP_PORT=80

# Database Settings
# Change these to strong passwords for the store deployment!
DB_ROOT_PASSWORD=root_password
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=app_password

# Web Administration Settings (Only used if uncommented in docker-compose.yml)
PHPMYADMIN_PORT=8080
PGADMIN_PORT=8081
PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=adminpassword

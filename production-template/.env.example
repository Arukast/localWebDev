# Application Configuration
APP_NAME=my-production-app
APP_PATH=./app
SYSTEM_TIMEZONE=UTC
DOMAIN_NAME=example.com
CERTBOT_EMAIL=admin@example.com
# Web Document Root inside container (default: /var/www/html, use /var/www/html/public for Laravel/Symfony)
NGINX_WEB_ROOT=/var/www/html

# HTTP / HTTPS Port Settings
APP_PORT=80
APP_SSL_PORT=443

# Database Settings
DB_ROOT_PASSWORD=strong_production_root_password
DB_NAME=app_production_db
DB_USER=app_production_user
DB_PASSWORD=strong_production_user_password

# Redis Settings (Optional)
REDIS_PORT=6379
REDIS_PASSWORD=strong_redis_production_password

# Offsite S3 Storage Settings (Optional for backup.sh)
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=us-east-1

# Web Administration Settings (Shifted up to avoid local dev dashboard clashes)
PHPMYADMIN_PORT=8880
PGADMIN_PORT=8881
PGADMIN_DEFAULT_EMAIL=admin@production.internal
PGADMIN_DEFAULT_PASSWORD=strong_admin_password


